generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     Int                     @id @default(autoincrement())
  name                   String
  username               String?                 @unique
  email                  String?                 @unique
  password               String
  plainPassword          String?
  role                   String                  @default("user")
  createdAt              DateTime                @default(now())
  predictions            Prediction[]
  championPrediction     ChampionPrediction?
  groupPredictions       GroupPrediction[]
  advancementPredictions AdvancementPrediction[]
  triviaResponses        TriviaResponse[]
}

model GroupPrediction {
  id      Int    @id @default(autoincrement())
  userId  Int
  group   String
  pos1    String @default("")
  pos2    String @default("")
  pos3    String @default("")
  pos4    String @default("")
  points  Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, group])
}

model Team {
  id          Int     @id @default(autoincrement())
  name        String
  group       String
  flag        String
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id             Int          @id @default(autoincrement())
  matchNumber    Int          @unique
  phase          String
  group          String?
  matchday       Int?
  homeTeamId     Int?
  awayTeamId     Int?
  homeTeam       Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam       Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeScore      Int?
  awayScore      Int?
  penaltyWinner  String?
  date           DateTime
  venue          String?
  city           String?
  status         String       @default("pending")
  label          String?
  predictions    Prediction[]
}

model Prediction {
  id            Int    @id @default(autoincrement())
  userId        Int
  matchId       Int
  homeScore     Int
  awayScore     Int
  penaltyWinner String?
  points        Int    @default(0)
  user          User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match         Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model ScoringConfig {
  id            Int    @id @default(autoincrement())
  phase         String @unique
  label         String @default("")
  exactScore    Int    @default(3)
  correctResult Int    @default(1)
}

model ChampionPrediction {
  id             Int    @id @default(autoincrement())
  userId         Int    @unique
  champion       String @default("")
  runnerUp       String @default("")
  third          String @default("")
  topScorer      String @default("")
  bestPlayer     String @default("")
  bestGoalkeeper String @default("")
  points         Int    @default(0)
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdvancementPrediction {
  id       Int    @id @default(autoincrement())
  userId   Int
  round    String
  teamName String
  points   Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, round, teamName])
}

model TriviaQuestion {
  id            Int              @id @default(autoincrement())
  question      String
  type          String           @default("multiple")
  options       String[]
  correctAnswer String
  isActive      Boolean          @default(false)
  expiresAt     DateTime?
  homeLabel     String           @default("")
  awayLabel     String           @default("")
  createdAt     DateTime         @default(now())
  responses     TriviaResponse[]
}

model TriviaResponse {
  id         Int            @id @default(autoincrement())
  questionId Int
  userId     Int
  answer     String
  isCorrect  Boolean
  createdAt  DateTime       @default(now())
  question   TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}
